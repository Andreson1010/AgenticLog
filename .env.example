# LMStudio credentials (required)
OPENAI_API_KEY=hermes
OPENAI_API_BASE=http://127.0.0.1:1234/v1

# LLM_MODEL: model name passed to the OpenAI-compatible client (default: hermes-3-llama-3.2-3b)
# LLM_MODEL=hermes-3-llama-3.2-3b

# Logging configuration (optional)
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL (default: INFO)
LOG_LEVEL=INFO

# LOG_FORMAT: text | json (default: text)
# Use json for structured log ingestion (e.g., CI pipelines, log aggregators)
LOG_FORMAT=text
